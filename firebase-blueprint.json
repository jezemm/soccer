{
  "entities": {
    "Game": {
      "title": "Game",
      "description": "A scheduled soccer game with assigned parent duties.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "opponent": { "type": "string" },
        "location": { "type": "string" },
        "mapUrlOverride": { "type": "string", "description": "Custom Google Maps link override" },
        "isHome": { "type": "boolean" },
        "snackProvider": { "type": "string", "description": "Name of the parent providing snacks" },
        "pitchMarshal": { "type": "string", "description": "Name of the parent on pitch marshal duty" },
        "referee": { "type": "string", "description": "Name of the parent refereeing" },
        "goalie": { "type": "string", "description": "Name of the player on goalie duty" },
        "snackSwapRequested": { "type": "boolean" },
        "marshalSwapRequested": { "type": "boolean" },
        "refereeSwapRequested": { "type": "boolean" },
        "goalieSwapRequested": { "type": "boolean" },
        "matchWrap": { "type": "string", "description": "Global match summary from the coach" }
      },
      "required": ["date", "opponent", "location", "isHome"]
    },
    "PlayerFeedback": {
      "title": "Player Feedback",
      "description": "Coach feedback and goals for a specific player in a match.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "gameId": { "type": "string" },
        "playerName": { "type": "string" },
        "feedback": { "type": "string" },
        "goals": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A chat message between two players.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sender": { "type": "string" },
        "receiver": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["sender", "receiver", "content", "timestamp"]
    },
    "Block": {
      "title": "Block",
      "description": "A record indicating one player has blocked another.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "blocker": { "type": "string" },
        "blocked": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["blocker", "blocked", "timestamp"]
    },
    "Profile": {
      "title": "Profile",
      "description": "Player bio and photo stats.",
      "type": "object",
      "properties": {
        "skills": { "type": "string" },
        "photoUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "User": {
      "title": "User",
      "description": "A parent or coach using the app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings like training status.",
      "type": "object",
      "properties": {
        "trainingCancelled": { "type": "boolean" },
        "trainingLocation": { "type": "string" },
        "coachChild": { "type": "string" },
        "coachExemptDuties": { "type": "array", "items": { "type": "string" } }
      }
    },
    "CoachAnnouncement": {
      "title": "Coach Announcement",
      "description": "General team-wide updates or match goals not tied to a specific game.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["message", "goal"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "type", "timestamp"]
    },
    "Availability": {
      "title": "Availability",
      "description": "Information about a player being unavailable for a specific date.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Format: playerName_dateKey" },
        "playerName": { "type": "string" },
        "dateKey": { "type": "string", "description": "Format: YYYY-MM-DD" },
        "isUnavailable": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["playerName", "dateKey", "isUnavailable", "updatedAt"]
    },
    "DutyConfig": {
      "title": "Duty Configuration",
      "description": "Configuration for a specific team duty.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Duty name (e.g., snackProvider, goalie)" },
        "label": { "type": "string" },
        "type": { "type": "string", "enum": ["player", "parent"] },
        "maxPerWeek": { "type": "number" },
        "maxPerType": { "type": "number" }
      },
      "required": ["id", "label", "type", "maxPerWeek", "maxPerType"]
    }
  },
  "firestore": {
    "games": {
      "schema": "Game",
      "description": "Collection of all games in the season."
    },
    "feedback": {
      "schema": "PlayerFeedback",
      "description": "Individual player feedback for each match."
    },
    "messages": {
      "schema": "Message",
      "description": "Chat messages."
    },
    "blocks": {
      "schema": "Block",
      "description": "User block configurations."
    },
    "profiles": {
      "schema": "Profile",
      "description": "Public player profiles."
    },
    "users": {
      "schema": "User",
      "description": "Registered parents/users."
    },
    "settings": {
      "schema": "Settings",
      "description": "System wide settings (e.g. trainingCancelled)."
    },
    "announcements": {
      "schema": "CoachAnnouncement",
      "description": "General coach announcements and team goals."
    },
    "availabilities": {
      "schema": "Availability",
      "description": "Player unavailability records indexed by date."
    },
    "dutiesConfig": {
      "schema": "DutyConfig",
      "description": "Configuration for team duties."
    }
  }
}
